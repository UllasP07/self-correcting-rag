# Copy to .env and adjust if needed. Defaults match the local Ollama + Docker setup.

# --- Ollama (local LLM + embeddings) ---
OLLAMA_URL=http://localhost:11434
CHAT_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768                 # nomic-embed-text outputs 768-dim vectors

# --- Qdrant (vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_docs

# --- Chunking (Milestone 1: simple recursive splitter) ---
CHUNK_SIZE=800               # target characters per chunk
CHUNK_OVERLAP=120            # overlap between adjacent chunks

# --- Retrieval ---
TOP_K=5                      # how many chunks to retrieve per query

# --- Provider selection ---
# "ollama" (local, free, default) or "azure" (Azure OpenAI). Set independently.
CHAT_PROVIDER=ollama
EMBED_PROVIDER=ollama

# --- Azure OpenAI (only needed when a provider above is "azure") ---
# From the Azure OpenAI / Foundry portal. The deployment names are what YOU
# named your model deployments (not the base model names).
AZURE_OPENAI_ENDPOINT=            # e.g. https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small
