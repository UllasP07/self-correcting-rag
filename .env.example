# Copy to .env and adjust if needed. Defaults match the local Ollama + Docker setup.

# --- Ollama (local LLM + embeddings) ---
OLLAMA_URL=http://localhost:11434
CHAT_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768                 # nomic-embed-text outputs 768-dim vectors

# --- Qdrant (vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=enterprise_docs

# --- Chunking (Milestone 1: simple recursive splitter) ---
CHUNK_SIZE=800               # target characters per chunk
CHUNK_OVERLAP=120            # overlap between adjacent chunks

# --- Retrieval ---
TOP_K=5                      # how many chunks to feed the LLM per query

# --- Reranking (Milestone 3) ---
# RERANK=true: fetch RETRIEVE_K candidates by cosine, then a cross-encoder
# re-scores them and keeps the best TOP_K. First query downloads ~1GB model.
# Set RERANK=false for pure cosine retrieval (no model, lighter).
RERANK=true
RETRIEVE_K=20
RERANK_MODEL=BAAI/bge-reranker-base

# --- CRAG self-correcting loop (Milestone 4) ---
# CRAG=true: grade the retrieved context; if it's too weak, rewrite the query
# and retrieve again (up to CRAG_MAX_REWRITES times) before answering. Fully
# local. Set CRAG=false for the pre-M4 linear retrieve->generate path.
CRAG=true
CRAG_GRADE_MIN_SCORE=0.6     # top rerank score >= this skips the LLM grader (fast pre-gate)
CRAG_MAX_REWRITES=1          # how many query rewrites to attempt on weak retrieval

# --- Text-to-SQL routing (Milestone 5) ---
# SQL_ENABLED=true: a router sends data questions (counts/averages/salaries) to a
# text-to-SQL node over a local SQLite DB; prose questions go to the doc loop.
# Generated SQL is validated read-only (SELECT only) before it runs.
# Set SQL_ENABLED=false to route everything to documents.
SQL_ENABLED=true
SQLITE_PATH=data/acme.db     # local structured DB (build with: python -m src.rag.seed_db)
SQL_MAX_ROWS=50              # cap rows fed back to the LLM

# --- Human-in-the-loop approval for risky SQL (Milestone 6) ---
# Risky queries FREEZE before running: state is checkpointed to disk and an admin
# must approve/deny (python -m src.rag.admin). "Risky" = reads a sensitive column
# OR is an unbounded full-table scan.
HITL_ENABLED=true
SENSITIVE_COLUMNS=salary     # comma-separated columns that require approval to read
HITL_FLAG_BROAD_SCANS=true   # also freeze unbounded scans (no WHERE/LIMIT, non-aggregate)
CHECKPOINT_PATH=data/checkpoints.db   # durable LangGraph checkpoint store

# --- I/O guardrails (Milestone 7) ---
# Firewall around answer_question: block prompt-injection/toxic INPUT before the
# model sees it, and mask PII / flag toxicity in the OUTPUT before it's shown.
GUARDRAILS_ENABLED=true
GUARD_INJECTION=true          # block prompt-injection attempts
GUARD_TOXICITY=true           # screen toxic input and output
GUARD_USE_LLM=false           # optional LLM second opinion (heuristics run first)
PII_BACKEND=regex             # "regex" (default, zero-dep) or "presidio" (lazy, heavier)
PII_ENTITIES=EMAIL,PHONE,SSN,CREDIT_CARD,IP   # entity types to mask in answers

# --- Eval + observability (Milestone 8) ---
# FastAPI service (python -m src.rag.server) serves /ask + /metrics on this port;
# the Prometheus/Grafana stack in docker-compose scrapes it.
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
EVAL_SET_PATH=data/eval_set.json       # labeled questions for `python -m src.rag.eval`
EVAL_REPORT_PATH=data/eval_report.json # eval writes here; /metrics surfaces the scores

# --- Provider selection ---
# "ollama" (local, free, default) or "azure" (Azure OpenAI). Set independently.
CHAT_PROVIDER=ollama
EMBED_PROVIDER=ollama

# --- Azure OpenAI (only needed when a provider above is "azure") ---
# From the Azure OpenAI / Foundry portal. The deployment names are what YOU
# named your model deployments (not the base model names).
AZURE_OPENAI_ENDPOINT=            # e.g. https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_CHAT_DEPLOYMENT=gpt-4o-mini
AZURE_EMBED_DEPLOYMENT=text-embedding-3-small
